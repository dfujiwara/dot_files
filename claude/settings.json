{
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(curl:*)",
      "Bash(docker compose *)",
      "Bash(find:*)",
      "Bash(gh pr:*)",
      "Bash(git add *)",
      "Bash(git branch *)",
      "Bash(git commit *)",
      "Bash(git mv:*)",
      "Bash(git reset *)",
      "Bash(git restore *)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(psql:*)",
      "Bash(test:*)",
      "Bash(tree:*)",
      "Bash(uv run *)",
      "Bash(uv sync:*)",
      "Bash(wc:*)",
      "Skill(api-test)",
      "Skill(git-commit)",
      "Skill(psql)",
      "WebSearch"
